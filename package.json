{
  "name": "atria",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p ${PORT:-3000}",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint src/ server/",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:baseline": "node scripts/baseline-drizzle.mjs",
    "mc:event:ci": "node scripts/emit-mission-event.mjs ci_failure \"Atria CI failure\" \"Pipeline reported failure\" high",
    "mc:event:incident": "node scripts/emit-mission-event.mjs incident \"Atria incident\" \"Runtime incident reported\" high",
    "mc:event:support": "node scripts/emit-mission-event.mjs support_ticket \"Atria support escalation\" \"Support ticket escalated from Atria\" medium",
    "gate:integration": "./scripts/run-suite-with-dev.sh integration 3010",
    "gate:stress": "./scripts/run-suite-with-dev.sh stress 3011",
    "gate:health": "./scripts/run-suite-with-dev.sh health 3012",
    "dev:full": "concurrently -n api,expo -c blue,magenta \"npm run dev\" \"cd mobile && npx expo start --dev-client\"",
    "dev:mobile": "cd mobile && npx expo start --dev-client",
    "dev:phone": "./scripts/dev-phone.sh",
    "dev:phone:go": "EXPO_DEV_CLIENT=0 ./scripts/dev-phone.sh",
    "dev:phone:tunnel": "EXPO_MODE=tunnel ./scripts/dev-phone.sh",
    "dev:phone:clear": "EXPO_CLEAR=1 ./scripts/dev-phone.sh"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-toast": "^1.2.6",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "@tanstack/react-query": "^5.90.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.7",
    "geist": "^1.7.0",
    "lucide-react": "^0.487.0",
    "next": "~15.5.12",
    "onnxruntime-node": "^1.24.3",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.14",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "tailwindcss": "^4.0.0",
    "typescript": "5.9.3"
  }
}

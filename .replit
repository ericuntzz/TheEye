modules = ["nodejs-20", "python-3.11", "nix"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "npm run build && npm run start"]
deploymentTarget = "autoscale"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[workflows]
runButton = "Start Dev"

[[workflows.workflow]]
name = "Start Dev"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run dev"
waitForPort = 3000

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd vision-service && pip install -r requirements.txt && uvicorn main:app --reload --host 0.0.0.0 --port 8000"
waitForPort = 8000

[[workflows.workflow]]
name = "DB Push"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx drizzle-kit push"

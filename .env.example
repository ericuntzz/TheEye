# Core application runtime
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
CLAUDE_API_KEY=YOUR_ANTHROPIC_API_KEY

# Optional runtime overrides
MISSION_CONTROL_URL=https://mc.atria.so
MISSION_CONTROL_ENABLED=true

# Comma-separated browser origins that are allowed to call /api/* cross-origin.
# Same-origin requests always work automatically, including Vercel preview URLs.
CORS_ALLOWED_ORIGIN=https://atria.so,https://www.atria.so

# Development-only fallback for local testing without the ONNX model provisioned.
ALLOW_PLACEHOLDER_EMBEDDINGS=0

# Optional model override
ANTHROPIC_VISION_MODEL=

# Dedicated account for gate/integration smoke tests
GATE_TEST_EMAIL=
GATE_TEST_PASSWORD=

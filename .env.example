# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/atria

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude Vision API)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Mission Control Bridge (optional)
MISSION_CONTROL_ENABLED=true
MISSION_CONTROL_URL=http://127.0.0.1:4310

# Brand/domain defaults
NEXT_PUBLIC_APP_URL=https://app.atria.so
NEXT_PUBLIC_API_URL=https://api.atria.so
DOCS_URL=https://docs.atria.so
